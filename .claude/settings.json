{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Bash(cat .env*)",
      "Bash(cat ./.env*)",
      "Bash(cat */.env*)",
      "Bash(cat **/.env*)",
      "Bash(head .env*)",
      "Bash(head ./.env*)",
      "Bash(head */.env*)",
      "Bash(head **/.env*)",
      "Bash(tail .env*)",
      "Bash(tail ./.env*)",
      "Bash(tail */.env*)",
      "Bash(tail **/.env*)",
      "Bash(less .env*)",
      "Bash(less ./.env*)",
      "Bash(more .env*)",
      "Bash(more ./.env*)",
      "Bash(grep * .env*)",
      "Bash(grep * ./.env*)",
      "Bash(grep * */.env*)",
      "Bash(grep * **/.env*)",
      "Bash(awk * .env*)",
      "Bash(awk * ./.env*)",
      "Bash(sed * .env*)",
      "Bash(sed * ./.env*)",
      "Bash(xxd .env*)",
      "Bash(od .env*)",
      "Bash(strings .env*)",
      "PowerShell(Get-Content .env*)",
      "PowerShell(Get-Content ./.env*)",
      "PowerShell(Get-Content **/.env*)",
      "PowerShell(cat .env*)",
      "PowerShell(type .env*)",
      "PowerShell(Select-String * .env*)"
    ]
  }
}
